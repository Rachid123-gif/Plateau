generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  ADMIN
  MODERATOR
  PROFESSIONAL
  RECRUITER
  INSTITUTION
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum ExperienceLevel {
  STUDENT
  JUNIOR
  INTERMEDIATE
  SENIOR
  EXPERT
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LINK
}

enum LanguageLevel {
  NATIVE
  FLUENT
  CONVERSATIONAL
  BASIC
}

enum InstitutionType {
  SCHOOL
  UNIVERSITY
  ORGANIZATION
  ASSOCIATION
  OTHER
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum NotificationType {
  CONTACT_REQUEST
  CONTACT_RESPONSE
  PROFILE_VERIFIED
  PROFILE_REJECTED
  SYSTEM
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  supabaseId    String    @unique @map("supabase_id")
  role          UserRole  @default(PROFESSIONAL)
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  profile          Profile?
  sentRequests     ContactRequest[] @relation("SentRequests")
  receivedRequests ContactRequest[] @relation("ReceivedRequests")
  savedProfiles    SavedProfile[]
  notifications    Notification[]
  auditLogs        AuditLog[]       @relation("AuditActor")
  blogArticles     BlogArticle[]

  @@map("users")
}

// ==========================================
// PROFILE
// ==========================================

model Profile {
  id                  String             @id @default(cuid())
  userId              String             @unique @map("user_id")
  firstName           String             @map("first_name")
  lastName            String             @map("last_name")
  artistName          String?            @map("artist_name")
  slug                String             @unique
  bio                 String?
  phone               String?
  city                String?
  region              String?
  website             String?
  photoUrl            String?            @map("photo_url")
  cvUrl               String?            @map("cv_url")
  primaryProfessionId String?            @map("primary_profession_id")
  experienceLevel     ExperienceLevel    @default(JUNIOR) @map("experience_level")
  availabilityStatus  AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  verificationStatus  VerificationStatus @default(PENDING) @map("verification_status")
  isPublic            Boolean            @default(true) @map("is_public")
  profileCompleteness Int                @default(0) @map("profile_completeness")
  viewCount           Int                @default(0) @map("view_count")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryProfession Profession?         @relation("PrimaryProfession", fields: [primaryProfessionId], references: [id])
  professions       ProfileProfession[]
  skills            ProfileSkill[]
  experiences       Experience[]
  education         Education[]
  portfolio         PortfolioItem[]
  media             MediaAsset[]
  availability      AvailabilitySlot[]
  languages         ProfileLanguage[]
  reviews           AdminReview[]
  savedBy           SavedProfile[]

  @@index([city])
  @@index([verificationStatus])
  @@index([availabilityStatus])
  @@index([primaryProfessionId])
  @@map("profiles")
}

// ==========================================
// PROFESSIONS & SKILLS
// ==========================================

model ProfessionCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  nameAr      String?      @map("name_ar")
  slug        String       @unique
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  professions Profession[]

  @@map("profession_categories")
}

model Profession {
  id         String             @id @default(cuid())
  name       String             @unique
  nameAr     String?            @map("name_ar")
  slug       String             @unique
  categoryId String             @map("category_id")
  isActive   Boolean            @default(true) @map("is_active")
  sortOrder  Int                @default(0) @map("sort_order")
  createdAt  DateTime           @default(now()) @map("created_at")

  category           ProfessionCategory  @relation(fields: [categoryId], references: [id])
  primaryProfiles    Profile[]           @relation("PrimaryProfession")
  profileProfessions ProfileProfession[]

  @@map("professions")
}

model ProfileProfession {
  profileId    String @map("profile_id")
  professionId String @map("profession_id")

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profession Profession @relation(fields: [professionId], references: [id])

  @@id([profileId, professionId])
  @@map("profile_professions")
}

model SkillCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  skills    Skill[]

  @@map("skill_categories")
}

model Skill {
  id         String        @id @default(cuid())
  name       String        @unique
  categoryId String?       @map("category_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  category SkillCategory?  @relation(fields: [categoryId], references: [id])
  profiles ProfileSkill[]

  @@map("skills")
}

model ProfileSkill {
  profileId String @map("profile_id")
  skillId   String @map("skill_id")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id])

  @@id([profileId, skillId])
  @@map("profile_skills")
}

// ==========================================
// AVAILABILITY
// ==========================================

model AvailabilitySlot {
  id        String             @id @default(cuid())
  profileId String             @map("profile_id")
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  status    AvailabilityStatus
  note      String?
  createdAt DateTime           @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, startDate, endDate])
  @@map("availability_slots")
}

// ==========================================
// EXPERIENCE & EDUCATION
// ==========================================

model Experience {
  id          String  @id @default(cuid())
  profileId   String  @map("profile_id")
  title       String
  production  String?
  role        String?
  year        Int?
  description String?
  sortOrder   Int     @default(0) @map("sort_order")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id            String  @id @default(cuid())
  profileId     String  @map("profile_id")
  institutionId String? @map("institution_id")
  customInstitution String? @map("custom_institution")
  degree        String?
  field         String?
  startYear     Int?    @map("start_year")
  endYear       Int?    @map("end_year")
  description   String?

  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution Institution? @relation(fields: [institutionId], references: [id])

  @@map("education")
}

// ==========================================
// PORTFOLIO & MEDIA
// ==========================================

model PortfolioItem {
  id           String    @id @default(cuid())
  profileId    String    @map("profile_id")
  title        String
  description  String?
  type         MediaType
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  year         Int?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}

model MediaAsset {
  id        String    @id @default(cuid())
  profileId String    @map("profile_id")
  type      MediaType
  url       String
  filename  String
  size      Int
  mimeType  String    @map("mime_type")
  createdAt DateTime  @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("media_assets")
}

// ==========================================
// LANGUAGES
// ==========================================

model Language {
  id       String            @id @default(cuid())
  name     String            @unique
  code     String            @unique
  profiles ProfileLanguage[]

  @@map("languages")
}

model ProfileLanguage {
  profileId  String        @map("profile_id")
  languageId String        @map("language_id")
  level      LanguageLevel @default(CONVERSATIONAL)

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id])

  @@id([profileId, languageId])
  @@map("profile_languages")
}

// ==========================================
// INSTITUTIONS
// ==========================================

model Institution {
  id        String          @id @default(cuid())
  name      String          @unique
  type      InstitutionType
  city      String?
  website   String?
  logoUrl   String?         @map("logo_url")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")

  education Education[]

  @@map("institutions")
}

// ==========================================
// CONTACT REQUESTS
// ==========================================

model ContactRequest {
  id          String               @id @default(cuid())
  senderId    String               @map("sender_id")
  receiverId  String               @map("receiver_id")
  subject     String
  message     String
  status      ContactRequestStatus @default(PENDING)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  respondedAt DateTime?            @map("responded_at")

  sender   User @relation("SentRequests", fields: [senderId], references: [id])
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@index([receiverId, status])
  @@index([senderId])
  @@map("contact_requests")
}

// ==========================================
// SAVED PROFILES (FAVORITES)
// ==========================================

model SavedProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  profileId String   @map("profile_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@map("saved_profiles")
}

// ==========================================
// ADMIN & AUDIT
// ==========================================

model AdminReview {
  id         String             @id @default(cuid())
  profileId  String             @map("profile_id")
  reviewerId String             @map("reviewer_id")
  status     VerificationStatus
  comment    String?
  createdAt  DateTime           @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id])

  @@map("admin_reviews")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String   @map("actor_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ==========================================
// BLOG / JOURNAL
// ==========================================

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  articles    BlogArticle[]

  @@map("blog_categories")
}

model BlogArticle {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  excerpt        String?
  content        String        @db.Text
  coverUrl       String?       @map("cover_url")
  status         ArticleStatus @default(DRAFT)
  publishedAt    DateTime?     @map("published_at")
  authorId       String        @map("author_id")
  categoryId     String?       @map("category_id")
  readingTime    Int?          @map("reading_time")
  viewCount      Int           @default(0) @map("view_count")
  seoTitle       String?       @map("seo_title")
  seoDescription String?       @map("seo_description")
  tags           String[]      @default([])
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  author   User          @relation(fields: [authorId], references: [id])
  category BlogCategory? @relation(fields: [categoryId], references: [id])

  @@index([status, publishedAt])
  @@index([slug])
  @@map("blog_articles")
}
